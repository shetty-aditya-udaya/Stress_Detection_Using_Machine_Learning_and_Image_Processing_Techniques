{
    "version": 2,
    "builds": [
        {
            "src": "Stress-Detection-using-ML-and-Image-Processing-Techniques-main/StressDetection/wsgi.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/favicon.ico",
            "dest": "Stress-Detection-using-ML-and-Image-Processing-Techniques-main/StressDetection/wsgi.py"
        },
        {
            "src": "/(.*)",
            "dest": "Stress-Detection-using-ML-and-Image-Processing-Techniques-main/StressDetection/wsgi.py"
        }
    ],
    "env": {
        "PYTHONUNBUFFERED": "1"
    }
}